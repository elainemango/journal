<%- include("partials/header"); -%>

<h1>Compose</h1>

<form action= "/compose" method="POST">
    <div class="form-group"> 
        <label>Title</label>
        <input class="form-control" type="text" name="postTitle" autocomplete="off">
        <label>Post</label>
        <textarea class="form-control" name="postContent" rows="5"></textarea>
    </div>
    <button class="btn btn-primary" type="submit" name="post">Publish</button>
</form>


<%- include("partials/footer"); -%>

